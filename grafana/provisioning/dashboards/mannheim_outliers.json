      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "timescaledb"
          },
          "format": "time_series",
          "rawSql": "WITH outlier_ids AS (\n  WITH latest AS (\n    SELECT DISTINCT ON (location_id) location_id, value\n    FROM measurements WHERE metric = 'temperature'\n    AND time > now() - INTERVAL '30 minutes'\n    ORDER BY location_id, time DESC\n  ),\n  stats AS (SELECT AVG(value) AS mean, STDDEV(value) AS std FROM latest)\n  SELECT l.location_id FROM latest l, stats s\n  WHERE s.std > 0 AND ABS(l.value - s.mean) > ${sigma} * s.std\n)\nSELECT\n  time_bucket('10 minutes', m.time) AS time,\n  s.display_name,\n  AVG(m.value) - AVG(AVG(m.value)) OVER (PARTITION BY time_bucket('10 minutes', m.time)) AS \"\u0394 from mean (\u00b0C)\"\nFROM measurements m\nJOIN stations s ON s.location_id = m.location_id\nWHERE m.metric = 'temperature'\n  AND $__timeFilter(m.time)\n  AND m.location_id IN (SELECT location_id FROM outlier_ids)\nGROUP BY 1, s.display_name\nORDER BY 1",
          "refId": "A"
        }
      ],
      "title": "Outlier stations \u2014 deviation from network mean over time",
      "type": "timeseries"
    }
