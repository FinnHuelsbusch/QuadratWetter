{
  "__inputs": [],
  "__requires": [],
  "annotations": { "list": [] },
  "description": "Stations deviating significantly from the network mean",
  "editable": true,
  "id": null,
  "links": [
    { "title": "← Main", "url": "/d/mannheim-wetter", "type": "link", "targetBlank": false }
  ],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "Temperature Outliers",
      "type": "row"
    },
    {
      "datasource": { "type": "postgres", "uid": "timescaledb" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 2 },
            { "color": "red", "value": 3 }
          ]},
          "unit": "celsius"
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "deviation" },
            "properties": [
              { "id": "displayName", "value": "Δ from mean (°C)" },
              { "id": "unit", "value": "celsius" },
              { "id": "custom.width", "value": 160 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "°C" },
            "properties": [{ "id": "custom.width", "value": 100 }]
          }
        ]
      },
      "gridPos": { "h": 12, "w": 12, "x": 0, "y": 1 },
      "id": 1,
      "options": { "footer": { "show": false }, "showHeader": true },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "timescaledb" },
          "format": "table",
          "rawSql": "WITH latest AS (\n  SELECT DISTINCT ON (station_name) station_name, value\n  FROM measurements WHERE metric = 'temperature'\n  AND time > now() - INTERVAL '30 minutes'\n  ORDER BY station_name, time DESC\n),\nstats AS (\n  SELECT AVG(value) AS mean, STDDEV(value) AS std FROM latest\n)\nSELECT\n  l.station_name,\n  ROUND(l.value::numeric, 1) AS \"°C\",\n  ROUND((l.value - s.mean)::numeric, 2) AS deviation,\n  ROUND(s.mean::numeric, 1) AS \"network mean °C\"\nFROM latest l, stats s\nWHERE s.std > 0 AND ABS(l.value - s.mean) > ${sigma} * s.std\nORDER BY ABS(l.value - s.mean) DESC",
          "refId": "A"
        }
      ],
      "title": "Temperature — stations > ${sigma}σ from mean",
      "type": "table"
    },
    {
      "datasource": { "type": "postgres", "uid": "timescaledb" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "custom": { "hideFrom": { "legend": false, "tooltip": false, "viz": false } },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null },
              { "color": "green", "value": 15 },
              { "color": "yellow", "value": 25 },
              { "color": "orange", "value": 32 },
              { "color": "red", "value": 37 }
            ]
          },
          "unit": "celsius",
          "mappings": []
        },
        "overrides": []
      },
      "gridPos": { "h": 12, "w": 12, "x": 12, "y": 1 },
      "id": 2,
      "options": {
        "basemap": { "config": {}, "name": "Basemap", "type": "default" },
        "controls": { "mouseWheelZoom": true, "showAttribution": true, "showZoom": true },
        "layers": [
          {
            "config": {
              "showLegend": true,
              "style": {
                "color": { "field": "value", "fixed": "dark-green" },
                "opacity": 0.9,
                "size": { "field": "abs_dev", "fixed": 8, "max": 24, "min": 6 },
                "symbol": { "fixed": "img/icons/marker/circle.svg", "mode": "fixed" },
                "symbolAlign": { "h": "center", "v": "center" }
              }
            },
            "location": { "latitude": "lat", "longitude": "lon", "mode": "coords" },
            "name": "Outlier stations",
            "tooltip": true,
            "type": "markers"
          }
        ],
        "tooltip": { "mode": "details" },
        "view": { "allLayers": true, "id": "coords", "lat": 49.498, "lon": 8.49, "zoom": 11 }
      },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "timescaledb" },
          "format": "table",
          "rawSql": "WITH latest AS (\n  SELECT DISTINCT ON (m.station_name) m.station_name, m.value, s.lat, s.lon\n  FROM measurements m\n  JOIN stations s ON s.station_name = m.station_name\n  WHERE m.metric = 'temperature'\n  AND m.time > now() - INTERVAL '30 minutes'\n  AND s.lat IS NOT NULL\n  ORDER BY m.station_name, m.time DESC\n),\nstats AS (\n  SELECT AVG(value) AS mean, STDDEV(value) AS std FROM latest\n)\nSELECT\n  l.station_name, l.lat, l.lon, l.value,\n  ABS(l.value - s.mean) AS abs_dev\nFROM latest l, stats s\nWHERE s.std > 0 AND ABS(l.value - s.mean) > ${sigma} * s.std",
          "refId": "A"
        }
      ],
      "title": "Outlier Map (dot size = deviation magnitude)",
      "type": "geomap"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 13 },
      "id": 101,
      "title": "Outlier History",
      "type": "row"
    },
    {
      "datasource": { "type": "postgres", "uid": "timescaledb" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 1, "fillOpacity": 0 },
          "unit": "celsius"
        },
        "overrides": []
      },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 14 },
      "id": 3,
      "options": {
        "legend": { "calcs": ["lastNotNull", "min", "max"], "displayMode": "table", "placement": "right" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "timescaledb" },
          "format": "time_series",
          "rawSql": "SELECT time, value - AVG(value) OVER (PARTITION BY time_bucket('10 minutes', time)) AS \"Δ from mean (°C)\", station_name\nFROM (\n  SELECT\n    time_bucket('10 minutes', m.time) AS time,\n    m.station_name,\n    AVG(m.value) AS value\n  FROM measurements m\n  WHERE m.metric = 'temperature'\n    AND $__timeFilter(m.time)\n    AND m.station_name IN (\n      SELECT DISTINCT ON (station_name) station_name\n      FROM (\n        WITH latest AS (\n          SELECT DISTINCT ON (station_name) station_name, value\n          FROM measurements WHERE metric = 'temperature'\n          AND time > now() - INTERVAL '30 minutes'\n          ORDER BY station_name, time DESC\n        ),\n        stats AS (SELECT AVG(value) AS mean, STDDEV(value) AS std FROM latest)\n        SELECT l.station_name FROM latest l, stats s\n        WHERE s.std > 0 AND ABS(l.value - s.mean) > ${sigma} * s.std\n      ) o\n    )\n  GROUP BY 1, 2\n) bucketed\nORDER BY time",
          "refId": "A"
        }
      ],
      "title": "Outlier stations — deviation from network mean over time",
      "type": "timeseries"
    }
  ],
  "refresh": "5m",
  "schemaVersion": 39,
  "tags": ["weather", "mannheim", "outliers"],
  "templating": {
    "list": [
      {
        "current": { "text": "2", "value": "2" },
        "hide": 0,
        "label": "Sigma threshold",
        "name": "sigma",
        "options": [
          { "selected": false, "text": "1", "value": "1" },
          { "selected": true,  "text": "2", "value": "2" },
          { "selected": false, "text": "3", "value": "3" }
        ],
        "query": "1,2,3",
        "type": "custom"
      }
    ]
  },
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
  "timezone": "Europe/Berlin",
  "title": "Mannheim Wetter — Outliers",
  "uid": "mannheim-outliers",
  "version": 1
}
