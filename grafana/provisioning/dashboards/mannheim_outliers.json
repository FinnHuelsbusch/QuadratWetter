      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "timescaledb"
          },
          "format": "table",
          "rawSql": "WITH latest AS (\n  SELECT DISTINCT ON (m.location_id) m.location_id, m.value, s.lat, s.lon, s.display_name\n  FROM measurements m JOIN stations s ON s.location_id = m.location_id\n  WHERE m.metric = 'temperature' AND m.time > now() - INTERVAL '30 minutes'\n  AND s.lat IS NOT NULL\n  ORDER BY m.location_id, m.time DESC\n),\nstats AS (SELECT AVG(value) AS mean, STDDEV(value) AS std FROM latest)\nSELECT l.display_name AS \"Station\", l.lat, l.lon, l.value, ABS(l.value - s.mean) AS abs_dev\nFROM latest l, stats s\nWHERE s.std > 0 AND ABS(l.value - s.mean) > ${sigma} * s.std",
          "refId": "A"
        }
