      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "timescaledb"
          },
          "format": "table",
          "rawSql": "WITH latest AS (\n  SELECT DISTINCT ON (m.location_id) m.location_id, m.value, s.display_name\n  FROM measurements m JOIN stations s ON s.location_id = m.location_id\n  WHERE m.metric = 'temperature' AND m.time > now() - INTERVAL '30 minutes'\n  ORDER BY m.location_id, m.time DESC\n),\nstats AS (SELECT AVG(value) AS mean, STDDEV(value) AS std FROM latest)\nSELECT l.display_name AS station, ROUND(l.value::numeric,1) AS \"\u00b0C\",\n  ROUND((l.value - s.mean)::numeric,2) AS deviation,\n  ROUND(s.mean::numeric,1) AS \"network mean \u00b0C\"\nFROM latest l, stats s\nWHERE s.std > 0 AND ABS(l.value - s.mean) > ${sigma} * s.std\nORDER BY ABS(l.value - s.mean) DESC",
          "refId": "A"
        }
      ],
      "title": "Temperature \u2014 stations > ${sigma}\u03c3 from mean",
      "type": "table"
    },
